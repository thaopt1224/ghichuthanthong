# Firebase Web config — KHÔNG dùng serviceAccountKey.json cho web app
# Lấy tại: Firebase Console → Project Settings → Your apps → Web (</>)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=vo-han-ghi-chu.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=vo-han-ghi-chu
VITE_FIREBASE_STORAGE_BUCKET=vo-han-ghi-chu.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=154292011311
VITE_FIREBASE_APP_ID=your_app_id
VITE_APP_URL=https://your-project.web.app
